# Prevent the .installed lock file from being read over HTTP.
# After setup is complete, restrict this entire directory:
#   Option A — delete the install/ directory entirely.
#   Option B — uncomment the block below.

<Files ".installed">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Uncomment after installation is complete to block the whole installer:
# <IfModule mod_authz_core.c>
#     Require all denied
# </IfModule>
# <IfModule !mod_authz_core.c>
#     Order deny,allow
#     Deny from all
# </IfModule>
